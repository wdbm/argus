class ImageViewer(tk.Tk):
    def __init__(self, path: str = ".", status_messages: bool = True):
        resolved_directory, initial_image_path = resolve_input_target(path)
        files = collect_image_paths(resolved_directory)
        super().__init__()
        self.title("Argus")
        self.geometry("1000x740")

        # canvas for precise zoom/pan
        self.canvas = tk.Canvas(self, bg="black", highlightthickness=0)
        self.canvas.pack(fill="both", expand=True)

        # status bar: indexed recent directories and transient messages
        self.status = tk.Label(self, text="", anchor="w")
        self.status.pack(fill="x", side="bottom")
        self.status_bar_visible = True
        self.status_messages_enabled = status_messages
        self._status_message = None
        self._status_message_job = None
        self._refresh_status_recents()

        self.dir = resolved_directory
        self.files = files
        self.i = 0
        if initial_image_path is not None:
            try:
                self.i = self.files.index(initial_image_path)
            except ValueError as exc:
                raise ValueError(f"image is not available in directory listing: {initial_image_path}") from exc
        self.current_image_path = None
        self.current_img = None
        self.current_levels: list[Image.Image] = []
        self.current_future: Future | None = None
        self.current_photo = None
        self.canvas_img_id = None

        self.cache = ImageCache(max_items=5, workers=2)
        self._cache_pump_job = self.after(50, self._pump_cache_updates)
        self.help_dialog = None

        self.is_fullscreen = False
        self.zoom = 1.0
        self.ox = 0
        self.oy = 0
        self.drag_start = None
        self.last_selected_directories = []
        self.auto_center_on_resize = True

        # progressive render / debounce
        self._refine_job = None
        self._wheel_job = None
        self._pending_zoom = None

        # key bindings
        self.bind("<Right>", self.next_image)
        self.bind("<Left>", self.prev_image)
        self.bind("<Delete>", self.delete_to_trash)
        self.bind("<s>", self.open_save_dialog)
        self.bind("<space>", self.open_save_dialog)
        self.bind("h", self.toggle_status_bar)
        self.bind("<Control-s>", self.quick_save)
        for n in range(10):
            self.bind(f"<KeyPress-{n}>", lambda e, k=n: self.quick_save_to_index(k))
        self.bind("<F11>", self.toggle_fullscreen)
        self.bind("<F1>", self.toggle_help_dialog)
        self.bind("?", self.toggle_help_dialog)
        self.bind("<Escape>", self.escape_action)
        self.bind("<Configure>", self._maybe_resize)

        # keyboard zoom
        self.bind("+", lambda e: self.zoom_in_center())
        weq = lambda e: self.zoom_in_center()
        self.bind("=", weq)
        self.bind("-", lambda e: self.zoom_out_center())
        self.bind("<Key-plus>", lambda e: self.zoom_in_center())
        self.bind("<Key-equal>", lambda e: self.zoom_in_center())
        self.bind("<Key-minus>", lambda e: self.zoom_out_center())
        self.bind("<Control-KeyPress-0>", lambda e: self.zoom_reset())
        self.bind("<KP_Add>", lambda e: self.zoom_in_center())
        self.bind("<KP_Subtract>", lambda e: self.zoom_out_center())
        self.bind("<KP_0>", lambda e: self.zoom_reset())

        # mouse wheel zoom
        self.canvas.bind("<MouseWheel>", self._on_mousewheel)   # Windows/macOS
        self.canvas.bind("<Button-4>",  lambda e: self._queue_zoom_at(e.x, e.y, 1.1))   # X11
        self.canvas.bind("<Button-5>",  lambda e: self._queue_zoom_at(e.x, e.y, 1/1.1))

        # drag to pan, double-click for fullscreen
        self.canvas.bind("<ButtonPress-1>", self._start_pan)
        self.canvas.bind("<B1-Motion>",     self._do_pan)
        self.canvas.bind("<Double-Button-1>", self._toggle_fullscreen_from_double_click)

        if self.files:
            self._show_current()

        self.protocol("WM_DELETE_WINDOW", self._on_close)

    # files ------------------------------------------------------------

    def _pump_cache_updates(self):
        self._cache_pump_job = None
        self.cache.process_completed()
        if self.winfo_exists():
            self._cache_pump_job = self.after(50, self._pump_cache_updates)

    def _clear_help_dialog(self):
        self.help_dialog = None

    def toggle_help_dialog(self, event=None):
        focus = self.focus_get()
        if event is not None and getattr(event, "char", "") == "?" and focus is not None and focus.winfo_class() == "Entry":
            return None
        if self.help_dialog is not None and self.help_dialog.winfo_exists():
            dialog = self.help_dialog
            self.help_dialog = None
            dialog.destroy()
            return "break"
        self.help_dialog = ShortcutHelpDialog(self, SHORTCUT_HELP_ROWS, on_close=self._clear_help_dialog)
        return "break"

    # fit and render ---------------------------------------------------

    def _fit_scale(self, img_w, img_h):
        self.update_idletasks()
        cw = max(1, self.canvas.winfo_width())
        ch = max(1, self.canvas.winfo_height())
        return min(cw / img_w, ch / img_h)

    def _pick_source_for_size(self, target_w, target_h) -> Image.Image:
        candidates = [(self.current_img.width, self.current_img.height, self.current_img)]
        for m in self.current_levels:
            candidates.append((m.width, m.height, m))
        eligible = [c for c in candidates if c[0] >= target_w and c[1] >= target_h]
        if eligible:
            w, h, img = min(eligible, key=lambda t: t[0] * t[1])
            return img
        w, h, img = max(candidates, key=lambda t: t[0] * t[1])
        return img

    def _clamp_view_offsets(self, scale, canvas_width, canvas_height):
        img_w = self.current_img.width * scale
        img_h = self.current_img.height * scale

        if img_w <= canvas_width:
            self.ox = (canvas_width - img_w) / 2
        else:
            self.ox = min(0.0, max(canvas_width - img_w, self.ox))

        if img_h <= canvas_height:
            self.oy = (canvas_height - img_h) / 2
        else:
            self.oy = min(0.0, max(canvas_height - img_h, self.oy))

    def _render_on_canvas(self, resample=Image.Resampling.BILINEAR, refine=False):
        if not self.current_img: return

        base_w, base_h = self.current_img.width, self.current_img.height
        base_scale = self._fit_scale(base_w, base_h)
        scale = max(0.05, base_scale * self.zoom)

        cw = max(1, self.canvas.winfo_width())
        ch = max(1, self.canvas.winfo_height())

        self._clamp_view_offsets(scale, cw, ch)

        # compute visible image rectangle in original image coordinates
        # canvas (0, 0) maps to image (-ox, -oy) at scale
        x0_img = (0 - self.ox) / scale
        y0_img = (0 - self.oy) / scale
        x1_img = (cw - self.ox) / scale
        y1_img = (ch - self.oy) / scale

        # clip to image bounds
        x0_img = max(0.0, min(float(base_w), x0_img))
        y0_img = max(0.0, min(float(base_h), y0_img))
        x1_img = max(0.0, min(float(base_w), x1_img))
        y1_img = max(0.0, min(float(base_h), y1_img))

        if x1_img <= x0_img or y1_img <= y0_img:
            return # nothing visible (should not happen with clamping)

        # desired on-screen size of slice
        display_w = int((x1_img - x0_img) * scale)
        display_h = int((y1_img - y0_img) * scale)

        # safety cap
        if max(display_w, display_h) > MAX_RENDER_SIDE:
            clamp_ratio = MAX_RENDER_SIDE / max(display_w, display_h)
            display_w = max(1, int(display_w * clamp_ratio))
            display_h = max(1, int(display_h * clamp_ratio))

        # choose best source image and map crop to its coordinates
        src_img = self._pick_source_for_size(display_w, display_h)
        factor = src_img.width / base_w # scale from original to chosen source coordinates
        src_box = (
            int(x0_img * factor),
            int(y0_img * factor),
            int(x1_img * factor),
            int(y1_img * factor),
        )
        # crop & resize to on-screen size
        if src_box[2] <= src_box[0] or src_box[3] <= src_box[1]:
            return
        slice_img = src_img.crop(src_box)
        display = slice_img.resize((max(1, display_w), max(1, display_h)), resample)

        self.current_photo = ImageTk.PhotoImage(display)

        # where to draw it on canvas -- top-left of visible slice
        draw_x = int(max(self.ox, 0))
        draw_y = int(max(self.oy, 0))

        if self.canvas_img_id is None:
            self.canvas_img_id = self.canvas.create_image(draw_x, draw_y, image=self.current_photo, anchor="nw")
        else:
            self.canvas.itemconfigure(self.canvas_img_id, image=self.current_photo)
            self.canvas.coords(self.canvas_img_id, draw_x, draw_y)

        # optional refine pass
        if refine:
            if self._refine_job:
                try: self.after_cancel(self._refine_job)
                except Exception: pass
            self._refine_job = self.after_idle(self._refine_lanczos)

    def _refine_lanczos(self):
        self._refine_job = None
        self._render_on_canvas(resample=Image.Resampling.LANCZOS, refine=False)

    def _center_image(self):
        if not self.current_img: return
        base_scale = self._fit_scale(self.current_img.width, self.current_img.height)
        scale = max(0.05, base_scale * self.zoom)
        cw = max(1, self.canvas.winfo_width())
        ch = max(1, self.canvas.winfo_height())
        w = int(self.current_img.width * scale)
        h = int(self.current_img.height * scale)
        if max(w, h) > MAX_RENDER_SIDE:
            clamp_ratio = MAX_RENDER_SIDE / max(w, h)
            w = max(1, int(w * clamp_ratio))
            h = max(1, int(h * clamp_ratio))
        self.ox = (cw - w) // 2
        self.oy = (ch - h) // 2

    # preload neighbors ------------------------------------------------
    def _prefetch_neighbors(self):
        if not self.files: return
        if self.i + 1 < len(self.files):
            self.cache.request(self.files[self.i + 1])
        if self.i - 1 >= 0:
            self.cache.request(self.files[self.i - 1])

    def _show_current(self):
        path = self.files[self.i]
        self.current_image_path = path
        self.zoom = 1.0
        self.auto_center_on_resize = True

        self.current_future = self.cache.request(path)
        self.after(0, self._check_current_future)

        self.title(f"Argus - {path.name}")
        self._prefetch_neighbors()

    def _check_current_future(self):
        self.cache.process_completed()
        if not self.current_future: return
        if self.current_future.done():
            try:
                self.current_img, self.current_levels = self.current_future.result()
            except Exception as e:
                messagebox.showerror("Error", f"Failed to open image:\n{e}")
                return
            self._center_image()
            self._render_on_canvas(resample=Image.Resampling.BILINEAR, refine=True)
        else:
            self.after(10, self._check_current_future)

    def _maybe_resize(self, event=None):
        if self.current_img and self.canvas.winfo_width() > 1 and self.canvas.winfo_height() > 1:
            # keep fit-to-window images centred after resize unless view was adjusted manually
            if self.auto_center_on_resize:
                self._center_image()
            self._render_on_canvas(resample=Image.Resampling.BILINEAR, refine=True)

    # navigation (wrapped) ---------------------------------------------
    def next_image(self, event=None):
        if not self.files: return
        self.i = (self.i + 1) % len(self.files)
        self._show_current()

    def prev_image(self, event=None):
        if not self.files: return
        self.i = (self.i - 1) % len(self.files)
        self._show_current()

    # fullscreen -------------------------------------------------------
    def toggle_fullscreen(self, event=None):
        self.is_fullscreen = not self.is_fullscreen
        self.attributes("-fullscreen", self.is_fullscreen)

    def escape_action(self, event=None):
        if self.is_fullscreen:
            self.is_fullscreen = False
            self.attributes("-fullscreen", False)
        else:
            self._on_close()

    # zoom helpers -----------------------------------------------------
    def _apply_zoom_at(self, cx, cy, factor, progressive=True):
        if not self.current_img: return
        self.auto_center_on_resize = False
        img = self.current_img
        base_scale = self._fit_scale(img.width, img.height)
        old_scale = max(0.05, base_scale * self.zoom)

        img_x = (cx - self.ox) / old_scale
        img_y = (cy - self.oy) / old_scale

        trial_zoom = min(8.0, max(0.125, self.zoom * factor))
        trial_scale = max(0.05, base_scale * trial_zoom)

        trial_w = img.width * trial_scale
        trial_h = img.height * trial_scale
        if max(trial_w, trial_h) > MAX_RENDER_SIDE:
            clamp_ratio = MAX_RENDER_SIDE / max(trial_w, trial_h)
            trial_scale *= clamp_ratio
            trial_zoom = trial_scale / base_scale

        self.zoom = trial_zoom
        new_scale = trial_scale

        self.ox = cx - img_x * new_scale
        self.oy = cy - img_y * new_scale

        if progressive:
            self._render_on_canvas(resample=Image.Resampling.BILINEAR, refine=True)
        else:
            self._render_on_canvas(resample=Image.Resampling.LANCZOS, refine=False)

    def zoom_in_center(self, step=0.1):
        cw = max(1, self.canvas.winfo_width()); ch = max(1, self.canvas.winfo_height())
        self._apply_zoom_at(cw // 2, ch // 2, 1 + step, progressive=True)

    def zoom_out_center(self, step=0.1):
        cw = max(1, self.canvas.winfo_width()); ch = max(1, self.canvas.winfo_height())
        self._apply_zoom_at(cw // 2, ch // 2, 1 / (1 + step), progressive=True)

    def zoom_reset(self):
        self.zoom = 1.0
        self.auto_center_on_resize = True
        self._center_image()
        self._render_on_canvas(resample=Image.Resampling.BILINEAR, refine=True)

    # debounced wheel --------------------------------------------------
    def _queue_zoom_at(self, cx, cy, factor):
        if self._pending_zoom is None:
            self._pending_zoom = {"cx": cx, "cy": cy, "factor": factor}
        else:
            self._pending_zoom["cx"] = cx
            self._pending_zoom["cy"] = cy
            self._pending_zoom["factor"] *= factor
        if self._wheel_job is None:
            self._wheel_job = self.after(16, self._flush_wheel_zoom)

    def _flush_wheel_zoom(self):
        self._wheel_job = None
        pz = self._pending_zoom
        if not pz: return
        self._pending_zoom = None
        self._apply_zoom_at(pz["cx"], pz["cy"], pz["factor"], progressive=True)

    def _on_mousewheel(self, event):
        factor = 1.1 if event.delta > 0 else 1/1.1
        self._queue_zoom_at(event.x, event.y, factor)

    # pan (drag) -------------------------------------------------------
    def _start_pan(self, event):
        self.drag_start = (event.x, event.y, self.ox, self.oy)

    def _do_pan(self, event):
        if not self.drag_start: return
        self.auto_center_on_resize = False
        sx, sy, ox0, oy0 = self.drag_start
        self.ox = ox0 + (event.x - sx)
        self.oy = oy0 + (event.y - sy)
        self._render_on_canvas(resample=Image.Resampling.BILINEAR, refine=False)

    def _toggle_fullscreen_from_double_click(self, event=None):
        self.drag_start = None
        self.toggle_fullscreen(event)

    # save flow --------------------------------------------------------
    def _copy_current_image_to_directories(self, destination_directories: list[Path], name: str):
        src = self.current_image_path
        saved_directories = []
        errors = []
        for destination_directory in [Path(d).resolve() for d in destination_directories]:
            try:
                destination_directory.mkdir(parents=True, exist_ok=True)
                add_recent_dir(str(destination_directory))
                dst = unique_destination_path(destination_directory, name)
                shutil.copy2(src, dst)
                saved_directories.append(destination_directory)
            except Exception as e:
                errors.append((str(destination_directory), str(e)))
        return saved_directories, errors

    def _format_directory_summary(self, directories: list[Path]):
        labels = [d.name or str(d) for d in directories]
        if len(labels) == 1:
            return labels[0]
        if len(labels) == 2:
            return f"{labels[0]} and {labels[1]}"
        return f"{labels[0]}, {labels[1]}, and {len(labels) - 2} others"

    def _show_save_result(self, saved_directories: list[Path], errors: list[tuple[str, str]], name: str):
        if errors and saved_directories:
            messagebox.showwarning("Partial save", f"Saved to {len(saved_directories)} directory(ies), but {len(errors)} failed.")
        elif errors:
            messagebox.showerror("Save failed", "\n".join([f"{d}: {e}" for d, e in errors]))
        if saved_directories:
            self._refresh_status_recents()
            noun = "directory" if len(saved_directories) == 1 else "directories"
            summary = self._format_directory_summary(saved_directories)
            self._show_status_message(f"{name} saved to {noun} {summary}.")

    def open_save_dialog(self, event=None):
        if not self.current_image_path: return
        default_name = self.current_image_path.name
        RecentSaveDialog(
            self,
            self._save_to_directories,
            default_filename=default_name,
            last_selected=self.last_selected_directories,
            browse_initial_directory=self.current_image_path.parent,
        )

    def _save_to_directories(self, destination_directories: list[Path], typed_name: str):
        try:
            src_ext = self.current_image_path.suffix
            name = sanitise_filename(typed_name)
            if not Path(name).suffix:
                name = f"{name}{src_ext}"

            self.last_selected_directories = [Path(d).resolve() for d in destination_directories]
            saved_directories, errors = self._copy_current_image_to_directories(self.last_selected_directories, name)
            self._show_save_result(saved_directories, errors, name)
        except Exception as e:
            messagebox.showerror("Save failed", str(e))

    def quick_save(self, event=None):
        if not self.current_image_path: return
        targets = [Path(d).resolve() for d in self.last_selected_directories]
        if not targets:
            mru = most_recent_dir()
            if mru:
                targets = [mru]
            else:
                return self.open_save_dialog()

        name = self.current_image_path.name
        saved_directories, errors = self._copy_current_image_to_directories(targets, name)
        self._show_save_result(saved_directories, errors, name)

    def quick_save_to_index(self, idx: int):
        if not self.current_image_path: return
        target_directory = recent_dir_for_key(idx)
        if target_directory is None: return
        name = self.current_image_path.name
        saved_directories, errors = self._copy_current_image_to_directories([target_directory], name)
        self._show_save_result(saved_directories, errors, name)

    # delete (to trash) ------------------------------------------------
    def delete_to_trash(self, event=None):
        if not self.current_image_path: return
        if send2trash is None:
            messagebox.showerror(
                "send2trash not available"
            )
            return
        victim = self.current_image_path
        try:
            send2trash(str(victim))
        except Exception as e:
            messagebox.showerror("Delete failed", f"Could not move to trash:\n{e}")
            return
        self.cache.discard(victim)
        try:
            idx = self.files.index(victim)
        except ValueError:
            idx = self.i
        self.files = [p for p in self.files if p != victim]
        deleted_name = victim.name
        if not self.files:
            self.canvas.delete("all")
            self.canvas_img_id = None
            self.current_image_path = None
            self.current_img = None
            self.current_levels = []
            self.title("Argus -- (no images)")
            self._show_status_message(f"Moved {deleted_name} to trash.")
            return
        self.i = (max(0, idx) - 1) % len(self.files)
        self._show_current()
        self._show_status_message(f"Moved {deleted_name} to trash.")

    # status bar -------------------------------------------------------
    def toggle_status_bar(self, event=None):
        self.status_bar_visible = not self.status_bar_visible
        if self.status_bar_visible:
            self.status.pack(fill="x", side="bottom")
            self._render_status()
        else:
            self.status.pack_forget()
        self.update_idletasks()
        if self.current_img and self.canvas.winfo_width() > 1 and self.canvas.winfo_height() > 1:
            if self.auto_center_on_resize:
                self._center_image()
            self._render_on_canvas(resample=Image.Resampling.BILINEAR, refine=True)

    def _default_status_text(self):
        recents = indexed_recents()
        if not recents:
            return "Recent directories: (none)"
        parts = [f"{i}:{p.name or p}" for i, p in recents]
        return "Recent directories: " + "  |  ".join(parts)

    def _render_status(self):
        if self._status_message is None:
            self.status.config(text=self._default_status_text())
        else:
            self.status.config(text=self._status_message)

    def _clear_status_message(self):
        self._status_message_job = None
        self._status_message = None
        self._render_status()

    def _show_status_message(self, text: str):
        if not self.status_messages_enabled:
            return
        if self._status_message_job is not None:
            try:
                self.after_cancel(self._status_message_job)
            except Exception:
                pass
        self._status_message = text
        self._render_status()
        self._status_message_job = self.after(STATUS_MESSAGE_MS, self._clear_status_message)

    def _refresh_status_recents(self):
        self._render_status()

    # shutdown ---------------------------------------------------------
    def _on_close(self):
        if self._cache_pump_job is not None:
            try:
                self.after_cancel(self._cache_pump_job)
            except Exception:
                pass
            self._cache_pump_job = None
        if self.help_dialog is not None and self.help_dialog.winfo_exists():
            self.help_dialog.destroy()
            self.help_dialog = None
        try:
            self.cache.shutdown()
        except Exception:
            pass
        self.destroy()

if __name__ == "__main__":
    options = docopt(__doc__, version=__VERSION__)
    path = options["<path>"] or "."
    status_messages = options["--status-messages"] or not options["--no-status-messages"]
    try:
        application = ImageViewer(path=path, status_messages=status_messages)
    except ValueError as exc:
        raise SystemExit(f"{APPLICATION_NAME}: {exc}") from exc
    application.mainloop()
