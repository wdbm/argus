# recents --------------------------------------------------------------

def load_recents():
    if RECENTS_FILE.exists():
        try:
            data = json.loads(RECENTS_FILE.read_text())
            return [p for p in data if Path(p).is_dir()]
        except Exception:
            pass
    return []

def save_recents(recents):
    try:
        RECENTS_FILE.write_text(json.dumps(recents[:MAX_RECENTS], indent=2))
    except Exception:
        pass

def clear_recents():
    try:
        RECENTS_FILE.write_text("[]")
    except Exception:
        pass

def add_recent_dir(path_str):
    p = Path(path_str).resolve()
    if p.is_file(): p = p.parent
    path_str = str(p)
    recents = load_recents()
    if path_str in recents: recents.remove(path_str)
    recents.insert(0, path_str)
    save_recents(recents)
    return recents

def most_recent_dir():
    recents = load_recents()
    return Path(recents[0]).resolve() if recents else None

def all_recents():
    return [Path(p).resolve() for p in load_recents()[:MAX_RECENTS]]

def indexed_recents():
    return list(zip(RECENT_DIRECTORY_KEYS, all_recents()[:MAX_INDEXED_RECENTS]))

def recent_dir_for_key(key: int):
    for display_key, path in indexed_recents():
        if display_key == key:
            return path
    return None

def schedule_directory_chooser_resize(
    parent,
    width_scale: int = DIRECTORY_CHOOSER_WIDTH_SCALE,
    height_scale: int = DIRECTORY_CHOOSER_HEIGHT_SCALE
):
    if parent.tk.call("tk", "windowingsystem") != "x11":
        return

    chooser_path = f"{str(parent)}.__tk_choosedir" if str(parent) != "." else ".__tk_choosedir"
    parent.tk.eval(
        f"""
        namespace eval ::argus::dialogue {{}}
        proc ::argus::dialogue::resize_directory_chooser {{w width_scale height_scale retries}} {{
            if {{$retries <= 0}} {{
                return
            }}
            if {{![winfo exists $w]}} {{
                after 20 [list ::argus::dialogue::resize_directory_chooser $w $width_scale $height_scale [expr {{$retries - 1}}]]
                return
            }}
            update idletasks
            set base_width [winfo reqwidth $w]
            set base_height [winfo reqheight $w]
            if {{$base_width <= 1 || $base_height <= 1}} {{
                after 20 [list ::argus::dialogue::resize_directory_chooser $w $width_scale $height_scale [expr {{$retries - 1}}]]
                return
            }}
            set screen_width [winfo screenwidth $w]
            set screen_height [winfo screenheight $w]
            set target_width [expr {{min(int(round($base_width * $width_scale)), max(200, $screen_width - {DIRECTORY_CHOOSER_SCREEN_MARGIN}))}}]
            set target_height [expr {{min(int(round($base_height * $height_scale)), max(200, $screen_height - {DIRECTORY_CHOOSER_SCREEN_MARGIN}))}}]
            set x [expr {{max(0, ($screen_width - $target_width) / 2)}}]
            set y [expr {{max(0, ($screen_height - $target_height) / 2)}}]
            wm minsize $w $base_width $base_height
            wm geometry $w "${{target_width}}x${{target_height}}+${{x}}+${{y}}"
        }}
        """
    )
    parent.tk.call(
        "after",
        "idle",
        "::argus::dialogue::resize_directory_chooser",
        chooser_path,
        width_scale,
        height_scale,
        50,
    )

# utilities ------------------------------------------------------------

def unique_destination_path(destination_directory: Path, filename: str) -> Path:
    base = Path(filename).stem
    ext = Path(filename).suffix
    candidate = destination_directory / (base + ext)
    n = 1
    while candidate.exists():
        candidate = destination_directory / f"{base} (copy {n}){ext}"
        n += 1
    return candidate

def sanitise_filename(name: str) -> str:
    name = name.strip().replace(os.sep, "")
    return re.sub(r'[\x00-\x1f<>:"|?*]', "_", name) or "image"

def is_supported_image_path(path: Path) -> bool:
    return path.is_file() and path.suffix.lower() in SUPPORTED_IMAGE_SUFFIXES

def resolve_input_target(path_str: str) -> tuple[Path, Path | None]:
    path = Path(path_str).expanduser().resolve()
    if not path.exists():
        raise ValueError(f"path does not exist: {path}")
    if path.is_dir():
        return path, None
    if is_supported_image_path(path):
        return path.parent, path
    if path.is_file():
        raise ValueError(f"file type is not supported: {path}")
    raise ValueError(f"path is neither a regular file nor a directory: {path}")

def collect_image_paths(directory: Path):
    try:
        return sorted([path for path in directory.iterdir() if is_supported_image_path(path)])
    except OSError as exc:
        raise ValueError(f"could not inspect directory: {directory} ({exc})") from exc

# threaded image cache -------------------------------------------------

class ImageCache:
    """Small LRU cache of decoded PIL Images + mipmaps, loaded off-thread."""
    def __init__(self, max_items=5, workers=2):
        self.max_items = max_items
        self.cache = OrderedDict()
        self.futures: dict[Path, Future] = {}
        self.pool = ThreadPoolExecutor(max_workers=workers)
        self.completed = SimpleQueue()
        self.closed = False

    def _close_entry(self, orig: Image.Image, mips: list[Image.Image]):
        try:
            orig.close()
        except Exception:
            pass
        for mip in mips:
            try:
                mip.close()
            except Exception:
                pass

    def _close_result(self, data):
        orig, mips = data
        self._close_entry(orig, mips)

    def _build_mipmaps(self, base: Image.Image):
        mipmaps = []
        w, h = base.size
        while True:
            w //= 2; h //= 2
            if w < 1 or h < 1: break
            if min(w, h) < MIPMAP_MIN_SIDE: break
            lvl = base.resize((w, h), Image.Resampling.LANCZOS)
            mipmaps.append(lvl)
        return mipmaps

    def _load_image(self, path: Path):
        with Image.open(path) as im:
            im.load()
            orig = im.copy()
        mipmaps = self._build_mipmaps(orig)
        return (orig, mipmaps)

    def _store_completed(self, path: Path, fut: Future):
        if self.closed:
            try:
                self._close_result(fut.result())
            except Exception:
                pass
            return
        self.completed.put((path, fut))

    def process_completed(self):
        while True:
            try:
                path, fut = self.completed.get_nowait()
            except Empty:
                return

            if self.closed:
                try:
                    self._close_result(fut.result())
                except Exception:
                    pass
                continue

            if self.futures.get(path) is not fut:
                try:
                    self._close_result(fut.result())
                except Exception:
                    pass
                continue

            self.futures.pop(path, None)
            try:
                data = fut.result()
            except Exception:
                continue
            self.cache[path] = data
            while len(self.cache) > self.max_items:
                _, (orig, mips) = self.cache.popitem(last=False)
                self._close_entry(orig, mips)

    def request(self, path: Path) -> Future:
        self.process_completed()
        path = path.resolve()
        if path in self.cache:
            data = self.cache.pop(path)
            self.cache[path] = data
            f = Future()
            f.set_result(data)
            return f
        if path in self.futures:
            return self.futures[path]

        fut = self.pool.submit(self._load_image, path)
        self.futures[path] = fut
        fut.add_done_callback(lambda _f, p=path: self._store_completed(p, _f))
        return fut

    def discard(self, path: Path):
        self.process_completed()
        path = path.resolve()
        fut = self.futures.pop(path, None)
        if fut and not fut.done():
            fut.cancel()
        data = self.cache.pop(path, None)
        if data:
            orig, mips = data
            self._close_entry(orig, mips)

    def shutdown(self):
        self.closed = True
        self.process_completed()
        for fut in list(self.futures.values()):
            if not fut.done():
                fut.cancel()
        self.pool.shutdown(wait=False)
        for _, (orig, mips) in list(self.cache.items()):
            self._close_entry(orig, mips)
        self.cache.clear()
        self.futures.clear()

# dialogues ------------------------------------------------------------

class RecentSaveDialog(Toplevel):
    """
    multi-select dialogue with:
      - filename entry (pre-filled, editable)
      - toggle buttons for up to 20 recent directories (multi-select)
      - digit keys 1-9,0: toggle the indexed recent directories
      - Browse... to add/select a directory
      - Return: trigger the Save button
      - Save button writes to all selected directories + filename
      - clear recent directories
      - Alt+digit keys 1-9,0: immediate save to that indexed recent directory
    """
    def __init__(self, master, on_save, default_filename: str, last_selected=None, browse_initial_directory: Path | None = None):
        super().__init__(master)
        self.title("Save to...")
        self.resizable(False, False)
        self.on_save = on_save
        self.configure(padx=12, pady=12)
        self.transient(master)
        self.grab_set()
        self.selected_directories = set(str(Path(p).resolve()) for p in (last_selected or []))
        self.browse_initial_directory = (Path(browse_initial_directory).resolve() if browse_initial_directory else None)

        # filename row
        fn_frame = tk.Frame(self); fn_frame.grid(row=0, column=0, sticky="ew", pady=(0, 8))
        tk.Label(fn_frame, text="Filename:").pack(side="left")
        self.fn_var = tk.StringVar(value=default_filename)
        self.fn_entry = tk.Entry(fn_frame, textvariable=self.fn_var, width=48)
        self.fn_entry.pack(side="left", padx=(6, 0))

        # recents header
        hdr = tk.Frame(self); hdr.grid(row=1, column=0, sticky="ew")
        tk.Label(hdr, text="Recent directories (1-9,0 for top 10)", font=("TkDefaultFont", 10, "bold")).pack(side="left")
        tk.Button(hdr, text="Clear recent directories", command=self._clear_recents).pack(side="right")

        # recents grid (top 10 numbered)
        self.btn_frame = tk.Frame(self); self.btn_frame.grid(row=2, column=0, sticky="nsew", pady=(6, 6))
        self._render_recent_buttons()

        # selected indicator
        sel_frame = tk.Frame(self); sel_frame.grid(row=3, column=0, sticky="ew", pady=(0, 8))
        tk.Label(sel_frame, text="Selected:").pack(side="left")
        self.selected_var = tk.StringVar(value=self._selected_summary())
        tk.Label(sel_frame, textvariable=self.selected_var, anchor="w", width=56).pack(side="left", padx=(6, 0))

        # controls
        ctl = tk.Frame(self); ctl.grid(row=4, column=0, sticky="ew")
        self.save_btn = tk.Button(ctl, text="Save", state="disabled", command=self._do_save)
        self.save_btn.pack(side="right")
        tk.Button(ctl, text="Browse...", command=self._browse).pack(side="left", padx=(0, 6))
        tk.Button(ctl, text="Cancel", command=self._cancel).pack(side="left")

        # dialogue-local hotkeys
        self.bind("<s>", self._handle_save_keypress)
        self.bind("<S>", self._handle_save_keypress)
        self.bind("<Return>", self._trigger_save_button)
        self.bind("<KP_Enter>", self._trigger_save_button)
        self.bind("<Escape>", self._cancel)
        self.bind("<Tab>", self._focus_next_widget)
        self.bind("<ISO_Left_Tab>", self._focus_previous_widget)
        self.bind("<Shift-Tab>", self._focus_previous_widget)
        for n in range(10):
            self.bind(f"<KeyPress-{n}>", lambda e, k=n: self._toggle_index(k))
            self.bind(f"<KP_{n}>", lambda e, k=n: self._toggle_index(k))
            self.bind(f"<Alt-KeyPress-{n}>", lambda e, k=n: self._save_to_index(k))

        # centre on parent
        self.update_idletasks()
        x = master.winfo_rootx() + (master.winfo_width() - self.winfo_width()) // 2
        y = master.winfo_rooty() + (master.winfo_height() - self.winfo_height()) // 2
        self.geometry(f"+{x}+{y}")
        self.protocol("WM_DELETE_WINDOW", self._cancel)
        self.after_idle(self.focus_set)

        self._update_save_state()

    def _selected_summary(self):
        n = len(self.selected_directories)
        if n == 0: return "(none)"
        if n == 1: return list(self.selected_directories)[0]
        return f"{n} directories"

    def _refresh_selection_ui(self):
        self.selected_var.set(self._selected_summary())
        self._render_recent_buttons()
        self._update_save_state()


    def _refresh_parent_status(self):
        if hasattr(self.master, "_refresh_status_recents"):
            self.master._refresh_status_recents()

    def _focus_is_text_input(self):
        focus = self.focus_get()
        if focus is None:
            return False
        return focus.winfo_class() in {"Entry", "TEntry", "Text", "Spinbox"}

    def _focus_next_widget(self, event=None):
        current = self.focus_get() or self
        target = current.tk_focusNext()
        if target is not None:
            target.focus_set()
        return "break"

    def _focus_previous_widget(self, event=None):
        current = self.focus_get() or self
        target = current.tk_focusPrev()
        if target is not None:
            target.focus_set()
        return "break"

    def _render_recent_buttons(self):
        for w in self.btn_frame.winfo_children(): w.destroy()
        recents = all_recents()
        if not recents:
            tk.Label(self.btn_frame, text="(No recent directories yet)").pack()
            return
        columns = 2
        for position, p in enumerate(recents):
            column, row = (position % columns), (position // columns)
            path = str(p)
            short = p.name or path
            active = path in self.selected_directories
            if position < MAX_INDEXED_RECENTS:
                display_key = RECENT_DIRECTORY_KEYS[position]
                text = f"[{display_key}] {short}\n{path}"
            else:
                text = f"{short}\n{path}"
            button_kwargs = {
                "text": text,
                "justify": "left",
                "anchor": "w",
                "width": 44,
                "relief": ("sunken" if active else "raised"),
                "command": lambda pp=path: self._toggle_dir(pp),
            }
            if active:
                button_kwargs.update({
                    "bg": RECENT_DIRECTORY_BUTTON_SELECTED_BG,
                    "activebackground": RECENT_DIRECTORY_BUTTON_SELECTED_ACTIVE_BG,
                })
            b = tk.Button(self.btn_frame, **button_kwargs)
            b.grid(row=row, column=column, padx=4, pady=4, sticky="ew")

    def _toggle_dir(self, path):
        if path in self.selected_directories:
            self.selected_directories.remove(path)
        else:
            self.selected_directories.add(path)
        self._refresh_selection_ui()

    def _toggle_index(self, idx: int):
        if self._focus_is_text_input():
            return None
        target_directory = recent_dir_for_key(idx)
        if target_directory is None:
            return "break"
        self._toggle_dir(str(target_directory))
        return "break"

    def _browse_start_directory(self) -> str | None:
        if self.selected_directories:
            return sorted(self.selected_directories)[0]
        if self.browse_initial_directory is not None:
            return str(self.browse_initial_directory)
        return None

    def _browse(self):
        initial_directory = self._browse_start_directory()
        self.grab_release()
        try:
            schedule_directory_chooser_resize(self)
            d = filedialog.askdirectory(
                parent=self,
                title="Choose a directory to save to",
                initialdir=initial_directory,
            )
        finally:
            self.lift()
            self.focus_force()
            self.grab_set()
        if d:
            resolved_directory = Path(d).resolve()
            self.browse_initial_directory = resolved_directory
            add_recent_dir(str(resolved_directory))
            self.selected_directories.add(str(resolved_directory))
            self._refresh_selection_ui()
            self._refresh_parent_status()

    def _update_save_state(self):
        self.save_btn.config(state=("normal" if self.selected_directories else "disabled"))

    def _clear_recents(self):
        if messagebox.askyesno("Clear recent directories", "Clear the recent directories list?", parent=self):
            clear_recents()
            self.selected_directories.clear()
            self._refresh_selection_ui()
            self._refresh_parent_status()

    def _close_dialog(self):
        self.grab_release()
        self.destroy()

    def _save_to_index(self, idx: int):
        target_directory = recent_dir_for_key(idx)
        if target_directory is None:
            return "break"
        name = sanitise_filename(self.fn_var.get())
        if not name:
            messagebox.showerror("Invalid name", "Please enter a filename.", parent=self)
            return "break"
        self._close_dialog()
        self.on_save([target_directory], name)
        return "break"

    def _handle_save_keypress(self, event=None):
        if self._focus_is_text_input():
            return None
        self._do_save()
        return "break"

    def _trigger_save_button(self, event=None):
        if str(self.save_btn.cget("state")) != "disabled":
            self.save_btn.invoke()
        return "break"

    def _do_save(self):
        if not self.selected_directories:
            messagebox.showwarning("Choose directories", "Please select at least one directory.", parent=self)
            return
        name = sanitise_filename(self.fn_var.get())
        if not name:
            messagebox.showerror("Invalid name", "Please enter a filename.", parent=self)
            return
        self._close_dialog()
        directories = [Path(p).resolve() for p in self.selected_directories]
        self.on_save(directories, name)

    def _cancel(self):
        self._close_dialog()
        return "break"

class ShortcutHelpDialog(Toplevel):
    def __init__(self, master, rows, on_close=None):
        super().__init__(master)
        self.title("Shortcuts")
        self.resizable(False, False)
        self.configure(padx=12, pady=12)
        self.transient(master)
        self.on_close = on_close

        tk.Label(self, text="Keyboard and mouse controls", font=("TkDefaultFont", 10, "bold")).pack(anchor="w")
        table = tk.Frame(self)
        table.pack(anchor="w", pady=(8, 12))
        for row_index, (shortcut, description) in enumerate(rows):
            tk.Label(
                table,
                text=shortcut,
                justify="left",
                anchor="w",
                font=("TkFixedFont", 10),
            ).grid(row=row_index, column=0, sticky="w", padx=(0, 18), pady=1)
            tk.Label(
                table,
                text=description,
                justify="left",
                anchor="w",
            ).grid(row=row_index, column=1, sticky="w", pady=1)
        tk.Button(self, text="Close", command=self._close).pack(anchor="e")

        self.bind("<Escape>", self._close)
        self.bind("<F1>", self._close)
        self.bind("?", self._close)

        self.update_idletasks()
        x = master.winfo_rootx() + (master.winfo_width() - self.winfo_width()) // 2
        y = master.winfo_rooty() + (master.winfo_height() - self.winfo_height()) // 2
        self.geometry(f"+{x}+{y}")
        self.protocol("WM_DELETE_WINDOW", self._close)
        self.focus_set()

    def _close(self, event=None):
        callback = self.on_close
        self.on_close = None
        if callback is not None:
            callback()
        self.destroy()
        return "break"

